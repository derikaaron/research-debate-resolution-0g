GROQ_API_KEY=your_groq_key_here

# ── Web Search (pick one provider) ──────────────────────────────────────────
# SEARCH_PROVIDER controls which backend is used. Options: tavily | serper | none
# Default: tavily
SEARCH_PROVIDER=tavily

# Tavily — recommended. Built specifically for LLM/agent use.
# Sign up: https://tavily.com — free tier is 1,000 searches/month, no credit card.
# After signup: dashboard → API Keys → copy key (starts with tvly-)
TAVILY_API_KEY=tvly-your_key_here

# Serper — alternative. Google Search via API.
# Sign up: https://serper.dev — free tier is 2,500 searches.
# Set SEARCH_PROVIDER=serper to use instead of Tavily.
SERPER_API_KEY=your_serper_key_here

# Set SEARCH_PROVIDER=none to disable real search entirely.
# Agents will receive [SEARCH UNAVAILABLE] blocks and lean UNCLEAR.
# Useful for testing the debate/judge logic without spending search quota.

# ── 0G Storage ───────────────────────────────────────────────────────────────
# Testnet wallet private key. Fund it from https://faucet.0g.ai
# Used for both storage uploads and registry contract transactions.
ZG_PRIVATE_KEY=0xyour_testnet_private_key_here

# Optional: override public testnet endpoints if you're hitting rate limits
# ZG_RPC_URL=https://evmrpc-testnet.0g.ai
# ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# ── Contract (filled in after running: npm run deploy:registry) ───────────────
REGISTRY_CONTRACT_ADDRESS=
